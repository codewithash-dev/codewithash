# Database (required for source code access storage)
DATABASE_URL="file:./prisma/dev.db"

# Stripe (required for paid source code)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: base URL for success/cancel redirects (defaults to Vercel URL or http://localhost:3000)
NEXT_PUBLIC_APP_URL=https://www.codewithash.com

# Membership tiers (Code With Ash Shop – like Code With Nomi)
# Supporter: recurring monthly. Platinum: one-time lifetime.
STRIPE_MEMBERSHIP_SUPPORTER_PRICE_ID=price_...   # $8/month subscription
STRIPE_MEMBERSHIP_PLATINUM_PRICE_ID=price_...    # $250 one-time

# Per-project Stripe Price IDs (create products in Stripe Dashboard, then set env)
# Format: STRIPE_PRICE_<SLUG> e.g. STRIPE_PRICE_ECOM, STRIPE_PRICE_CREATOR_ANALYTICS
# STRIPE_PRICE_ECOM=price_...
# STRIPE_PRICE_CREATOR_ANALYTICS=price_...

# Optional: per-project download URLs (e.g. S3 signed URL or static host)
# When set, "Download source code" will redirect here. Format: SOURCE_DOWNLOAD_<SLUG>
# SOURCE_DOWNLOAD_ECOM=https://...
# SOURCE_DOWNLOAD_CREATOR_ANALYTICS=https://...
